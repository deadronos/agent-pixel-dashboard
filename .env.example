# Dashboard
VITE_HUB_HTTP=http://localhost:3030
VITE_HUB_WS=ws://localhost:3030/ws

# Hub
HUB_PORT=3030
HUB_AUTH_TOKEN=dev-secret
CASS_BIN=cass

# Collector
COLLECTOR_ID=collector-local
COLLECTOR_HOST=localhost
HUB_URL=http://localhost:3030
HUB_AUTH_TOKEN=dev-secret
FLUSH_INTERVAL_MS=500
MAX_BATCH_BYTES=1500000
WATCH_SOURCES=auto
PLUGINS_DIR=plugins

# Optional session roots
CODEX_SESSION_ROOTS=
CLAUDE_SESSION_ROOTS=
GEMINI_SESSION_ROOTS=
OPENCLAW_SESSION_ROOTS=
COPILOT_SESSION_ROOTS=

# Optional watcher tuning
CODEX_ACTIVE_WINDOW_MS=120000
CLAUDE_ACTIVE_WINDOW_MS=120000
GEMINI_ACTIVE_WINDOW_MS=120000
OPENCLAW_ACTIVE_WINDOW_MS=120000
OPENCLAW_SCAN_INTERVAL_MS=15000
OPENCLAW_SCAN_MAX_DEPTH=8
OPENCLAW_SCAN_MAX_FILES=5000
COPILOT_ACTIVE_WINDOW_MS=120000
