{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@agent-watch/env-loader": ["packages/env-loader/src/index.ts"],
      "@agent-watch/event-schema": ["packages/event-schema/src/index.ts"],
      "@agent-watch/plugin-sdk": ["packages/plugin-sdk/src/index.ts"],
      "@agent-watch/plugin-codex-watch": ["plugins/plugin-codex-watch/src/index.ts"],
      "@agent-watch/plugin-claude-watch": ["plugins/plugin-claude-watch/src/index.ts"],
      "@agent-watch/plugin-gemini-watch": ["plugins/plugin-gemini-watch/src/index.ts"],
      "@agent-watch/plugin-hermes-watch": ["plugins/plugin-hermes-watch/src/index.ts"],
      "@agent-watch/plugin-openclaw-watch": ["plugins/plugin-openclaw-watch/src/index.ts"],
      "@agent-watch/plugin-opencode-watch": ["plugins/plugin-opencode-watch/src/index.ts"],
      "@agent-watch/plugin-pi-watch": ["plugins/plugin-pi-watch/src/index.ts"],
      "@agent-watch/plugin-copilot-watch": ["plugins/plugin-copilot-watch/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist"
  }
}
